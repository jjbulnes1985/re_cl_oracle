# RE_CL — Variables de entorno
# Copia este archivo a .env y completa los valores reales
# NUNCA commitees .env al repositorio

# ── Base de datos ──────────────────────────────────────────
POSTGRES_DB=re_cl
POSTGRES_USER=re_cl_user
POSTGRES_PASSWORD=cambia_esta_clave_segura
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL completa (construida a partir de las variables anteriores)
# DATABASE_URL=postgresql://re_cl_user:password@localhost:5432/re_cl

# ── Rutas de datos ─────────────────────────────────────────
# Ruta absoluta al CSV de transacciones (151 MB)
RAW_CSV_PATH=../data/raw/Transactions w.Const.date_v2.csv

# Directorio de salida para datos procesados
PROCESSED_DATA_DIR=../data/processed

# Directorio de exportación de mapas y rankings
EXPORTS_DIR=../data/exports

# ── Modelo ─────────────────────────────────────────────────
MODEL_VERSION=v1.0
# Tamaño de chunk para leer el CSV (filas por bloque)
CSV_CHUNK_SIZE=50000

# ── Scoring profiles ───────────────────────────────────────
# Perfil por defecto del pipeline: default | location | growth | liquidity | custom
SCORING_PROFILE=default
# Pesos para modo custom (se normalizan automáticamente a 1.0)
WEIGHT_UNDERVALUATION=0.70
WEIGHT_CONFIDENCE=0.30
WEIGHT_LOCATION=0.00
WEIGHT_GROWTH=0.00
WEIGHT_VOLUME=0.00

# ── Alertas ────────────────────────────────────────────────
# Score mínimo para generar alerta (0-1)
ALERT_MIN_SCORE=0.75
# Gap máximo permitido (negativo = subvalorado; -0.15 = 15% por debajo del valor predicho)
ALERT_MIN_GAP_PCT=-0.15
# Confianza mínima del dato (0-1)
ALERT_MIN_CONFIDENCE=0.65

# ── Email (opcional) ────────────────────────────────────────
# Dejar en blanco para desactivar notificaciones por email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASSWORD=tu_app_password_gmail
ALERT_EMAIL_FROM=tu_correo@gmail.com
ALERT_EMAIL_TO=destinatario@gmail.com

# ── Datos comunales ────────────────────────────────────────
# Ruta al CSV de crecimiento comunal (INE). Usa la ruta por defecto si no se indica.
# COMMUNE_GROWTH_CSV=data/processed/commune_growth_index.csv

# ── V4 Thesis ──────────────────────────────────────────────
# Reference year for age calculation (2014 = data cutoff)
AGE_REFERENCE_YEAR=2014

# ── V5 Safety Profile ──────────────────────────────────────
WEIGHT_CRIME=0.00
WEIGHT_CENSUS=0.00

# ── V5 Analytics ───────────────────────────────────────────
# Commune growth CSV (optional, uses default if not set)
# COMMUNE_GROWTH_CSV=data/processed/commune_growth_index.csv
# COMMUNE_INE_CSV=data/processed/commune_ine_census.csv
# COMMUNE_CRIME_CSV=data/processed/commune_crime_index.csv

# ── Scraping (V2) ──────────────────────────────────────────
# Valor UF aproximado para convertir CLP → UF en listings scrapeados
UF_VALUE_APPROX=37000

# ── Data Inmobiliaria (CBR ventas efectivas 2008-present) ──
# Registro gratuito en https://datainmobiliaria.cl/users/sign_in
DATA_INMOBILIARIA_EMAIL=tu_correo@gmail.com
DATA_INMOBILIARIA_PASSWORD=tu_password

# ── ieut-inciti shapefiles ─────────────────────────────────
# IEUT_DATA_DIR=C:\ruta\a\ieut - inciti\Data

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
